{
  "name": "yarik",
  "type": "module",
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "dev:bot": "cd apps/bot && bun run dev",
    "start:bot": "cd apps/bot && bun run start",
    "dev:web": "cd apps/web && bun run dev",
    "build:web": "cd apps/web && bun run build",
    "typecheck": "cd apps/bot && bun run typecheck && cd ../web && bun run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "check": "bun run typecheck && bun run lint"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "eslint": "^10.5.0"
  }
}
